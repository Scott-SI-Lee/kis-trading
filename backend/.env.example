# 한국투자증권 OpenAPI 설정
# 이 파일을 복사해서 .env 로 저장하고 실제 값을 입력하세요
# cp .env.example .env

# KIS Developer Portal에서 발급받은 키
KIS_APP_KEY=여기에_APP_KEY_입력
KIS_APP_SECRET=여기에_APP_SECRET_입력

# 계좌번호 (하이픈 포함, 예: 50123456-01)
KIS_ACCOUNT_NO=50123456-01

# 모의투자 여부 (true = 모의, false = 실전)
KIS_IS_MOCK=true

# 미국 마감 분석 브리프 알림 (선택)
TELEGRAM_BOT_TOKEN=123456789:AA...
TELEGRAM_CHAT_ID=123456789
US_CLOSE_TELEGRAM_ENABLED=false

# 자동 실행 스케줄 (선택)
US_CLOSE_SCHEDULE_ENABLED=true
US_CLOSE_SCHEDULE_HOUR=6
US_CLOSE_SCHEDULE_MINUTE=0
US_CLOSE_NEWS_WINDOW_HOURS=24
US_CLOSE_NEWS_PER_SOURCE=10
US_CLOSE_OUTPUT_DIR=./reports
